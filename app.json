{
  "expo": {
    "name": "001_AtlasWay",
    "slug": "001_AtlasWay",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "atlasway",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/funnel-display/FunnelDisplay-ExtraBold.ttf",
            "./assets/fonts/funnel-display/FunnelDisplay-Bold.ttf",
            "./assets/fonts/funnel-display/FunnelDisplay-SemiBold.ttf",
            "./assets/fonts/funnel-display/FunnelDisplay-Medium.ttf",
            "./assets/fonts/funnel-display/FunnelDisplay-Regular.ttf",
            "./assets/fonts/funnel-display/FunnelDisplay-Light.ttf",
            "./assets/fonts/outfit/Outfit-Black.ttf",
            "./assets/fonts/outfit/Outfit-ExtraBold.ttf",
            "./assets/fonts/outfit/Outfit-Bold.ttf",
            "./assets/fonts/outfit/Outfit-SemiBold.ttf",
            "./assets/fonts/outfit/Outfit-Medium.ttf",
            "./assets/fonts/outfit/Outfit-Regular.ttf",
            "./assets/fonts/outfit/Outfit-Light.ttf",
            "./assets/fonts/outfit/Outfit-ExtraLight.ttf",
            "./assets/fonts/outfit/Outfit-Thin.ttf"
          ],
          "android": {
            "fonts": [
              {
                "fontFamily": "Funnel Display",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/funnel-display/FunnelDisplay-Regular.ttf",
                    "weight": 400
                  }
                ]
              },
              {
                "fontFamily": "Outfit",
                "fontDefinitions": [
                  {
                    "path": "./assets/fonts/outfit/Outfit-Regular.ttf",
                    "weight": 400
                  }
                ]
              }
            ]
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
